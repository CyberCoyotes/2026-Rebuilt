# Default: normalize all text files to LF in repo
* text=auto eol=lf

# Java / Gradle / config
*.java text eol=lf
*.gradle text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts MUST stay LF
*.sh text eol=lf

# Windows batch files
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jar binary
*.wpilog binary